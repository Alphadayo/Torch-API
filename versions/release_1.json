class MyExtension {
    getInfo() {
        return {
            id: "torchapi",
            name: "Torch API",

            blocks: [
                {
                    opcode: "getUserData",
                    blockType: Scratch.BlockType.REPORTER,
                    text: "Fetch the [DATA] of user [USERNAME]",
                    arguments: {
                        USERNAME: {
                            type: Scratch.ArgumentType.STRING,
                            defaultValue: "CodeTorch"
                        },
                        DATA: {
                            type: Scratch.ArgumentType.STRING,
                            menu: "dataMenu",
                            defaultValue: "username"
                        }
                    }
                },
                {
                    opcode: "getProjectData",
                    blockType: Scratch.BlockType.REPORTER,
                    text: "Fetch the [PROJECTDATA] of project [PROJECTID]",
                    arguments: {
                        PROJECTID: {
                            type: Scratch.ArgumentType.NUMBER,
                            defaultValue: 1
                        },
                        PROJECTDATA: {
                            type: Scratch.ArgumentType.STRING,
                            menu: "projectDataMenu",
                            defaultValue: "title"
                        }
                    }
                }
            ],

            menus: {
                dataMenu: {
                    items: [
                        { text: "Username", value: "username" },
                        { text: "Display name", value: "display_name" },
                        { text: "Icon URL", value: "pfp" },
                        { text: "User ID", value: "id" },
                        { text: "Following", value: "following_count" },
                        { text: "Followers", value: "followers_count" }
                    ]
                },
                projectDataMenu: {
                    items: [
                        { text: "Title", value: "title" },
                        { text: "Thumbnail", value: "thumbnail" },
                        { text: "Project Type", value: "project_type" },
                        { text: "Views", value: "views_count" },
                        { text: "Loves", value: "loves_count" },
                        { text: "Likes", value: "likes_count" },
                        { text: "Comments Disabled", value: "comments_disabled" }
                    ]
                }
            }
        };
    }

    async getUserData(args) {
        try {
            const username = encodeURIComponent(args.USERNAME);

            const res = await fetch(`https://api.codetorch.net/v1/users/${username}`);
            if (!res.ok) return "";

            const data = await res.json();

            // 選択された項目を取得
            return data[args.DATA] ?? "None";

        } catch (e) {
            return "Communication failure";
        }
    }
    async getProjectData(args) {
        try {
            const projectId = encodeURIComponent(args.PROJECTID);

            const res = await fetch(`https://api.codetorch.net/v1/projects/${projectId}`);
            if (!res.ok) return "";

            const data = await res.json();

            // 選択された項目を取得
            return data[args.PROJECTDATA] ?? "None";

        } catch (e) {
            return "Communication failure";
        }
    }
}

Scratch.extensions.register(new MyExtension());
