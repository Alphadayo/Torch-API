class TorchAPI {
    getInfo() {
        return {
            id: "torchapi",
            name: "Torch API",
            menuIconURI: 'data:image/png;base64,',
            blockIconURI: 'data:image/png;base64,',
            color1: "#e43100",
            color2: "#cb2900",
            color3: "#9e1800",
            blocks: [
                {
                    opcode: "getUserData",
                    blockType: Scratch.BlockType.REPORTER,
                    text: Scratch.translate("Fetch the [DATA] of user [USERNAME]"),
                    arguments: {
                        USERNAME: {
                            type: Scratch.ArgumentType.STRING,
                            defaultValue: "CodeTorch"
                        },
                        DATA: {
                            type: Scratch.ArgumentType.STRING,
                            menu: "dataMenu", defaultValue: "username"
                        }
                    }
                },
                {
                    opcode: "getProjectData",
                    blockType: Scratch.BlockType.REPORTER,
                    text: Scratch.translate("Fetch the [DATA] of project [PROJECTID]"),
                    arguments: {
                        PROJECTID: {
                            type: Scratch.ArgumentType.NUMBER,
                            defaultValue: 1
                        },
                        DATA: {
                            type: Scratch.ArgumentType.STRING,
                            menu: "projectDataMenu", defaultValue: "title"
                        }
                    }
                },
                {
                    opcode: "getPostData",
                    blockType: Scratch.BlockType.REPORTER,
                    text: Scratch.translate("Fetch the [DATA] of post [POSTID]"),
                    arguments: {
                        POSTID: {
                            type: Scratch.ArgumentType.NUMBER,
                            defaultValue: 1
                        },
                        DATA: {
                            type: Scratch.ArgumentType.STRING,
                            menu: "postDataMenu", defaultValue: "author"
                        }
                    }
                },
                {
                    opcode: "getCustomAchievementData",
                    blockType: Scratch.BlockType.REPORTER,
                    text: Scratch.translate("Fetch the [DATA] of custom achievement [ACHIEVEMENTID] for project [PROJECTID]"),
                    arguments: {
                        ACHIEVEMENTID: {
                            type: Scratch.ArgumentType.NUMBER,
                            defaultValue: 1
                        },
                        PROJECTID: {
                            type: Scratch.ArgumentType.NUMBER,
                            defaultValue: 1
                        },
                        DATA: {
                            type: Scratch.ArgumentType.STRING,
                            menu: "achievementDataMenu", defaultValue: "name"
                        }
                    }
                }
            ],
            menus: {
                dataMenu: {
                    items: [
                        { text: "Username", value: "username" },
                        { text: "Display name", value: "display_name" },
                        { text: "Icon URL", value: "pfp" },
                        { text: "User ID", value: "id" },
                        { text: "Following", value: "following_count" },
                        { text: "Followers", value: "followers_count" },
                        { text: "Verification Status", value: "verified" }
                    ]
                },
                projectDataMenu: {
                    items: [
