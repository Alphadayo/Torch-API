    async getUserData(args) {
        try {
            const username = encodeURIComponent(args.USERNAME);
            const res = await fetch(`https://api.codetorch.net/v1/users/${username}`);
            if (!res.ok) return "";
            const data = await res.json();
            return data[args.DATA] ?? "None";
        } catch (e) {
            return "Communication failure";
        }
    }

    async getProjectData(args) {
        try {
            const projectId = encodeURIComponent(args.PROJECTID);
            const res = await fetch(`https://api.codetorch.net/v1/projects/${projectId}`);
            if (!res.ok) return "";
            const data = await res.json();
            if (args.DATA === "creator") return data.author?.username ?? "None";
            return data[args.DATA] ?? "None";
        } catch (e) {
            return "Communication failure";
        }
    }

    async getPostData(args) {
        try {
            const postId = encodeURIComponent(args.POSTID);
            const res = await fetch(`https://api.codetorch.net/v1/posts/${postId}`);
            if (!res.ok) return "";
            const data = await res.json();
            if (args.DATA === "author") return data.author?.username ?? "None";
            return data[args.DATA] ?? "None";
        } catch (e) {
            return "Communication failure";
        }
    }

    async getCustomAchievementData(args = {}) {
    try {
        const projectId = encodeURIComponent(args.PROJECTID ?? "");

        const res = await fetch(
            `https://api.codetorch.net/v1/projects/custom/${projectId}/achievements`
        );

        if (!res.ok) return "";

        const data = await res.json();

        if (args.ACHIEVEMENTID) {
            const item = data.find(item => item.id === args.ACHIEVEMENTID);
            return item?.[args.DATA] ?? "";
        }

        return JSON.stringify(data.map(item => item.id)) || "None";

    } catch (e) {
        return "Communication failure";
    }
    }

    async getCollectionData(args = {}) {
    try {
        const username = encodeURIComponent(args.USERNAME ?? "");

        const res = await fetch(
            `https://api.codetorch.net/v1/collections/users/${username}`
        );

        if (!res.ok) return "";

        const data = await res.json();

        if (args.COLLECTIONID) {
            const item = data.find(item => item.id === args.COLLECTIONID);
            return item?.[args.DATA] ?? "";
        }

        return JSON.stringify(data.map(item => item.id)) || "None";

    } catch (e) {
        return "Communication failure";
    }
    }

    async getLeaderboardData(args = {}) {
    try {
        const res = await fetch(
            `https://api.codetorch.net/v1/leaderboard/users`
        );

        if (!res.ok) return "";

        const data = await res.json();

        if (args.RANK) {
            const item = data.leaderboard[args.RANK-1];
            return item?.[args.DATA] ?? "";
        }

        return JSON.stringify(data.map(item => item.Username)) || "None";

    } catch (e) {
        return "Communication failure";
    }
    }

    async isUsernameAvailable(args = {}) {
    try {
        const username = encodeURIComponent(args.USERNAME ?? "");

        const res = await fetch(
            `https://api.codetorch.net/v1/users/check-username-availability?username=${username}`
        );

        if (!res.ok) return "";

        const data = await res.json();

        return data.is_available ?? "None";

    } catch (e) {
        return "Communication failure";
    }
    }
    }

